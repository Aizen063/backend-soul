API_BASE=https://backend-soul.onrender.com
IMPORT_TOKEN=replace-with-admin-jwt

# Optional: keep temporary downloads in a custom local folder
# IMPORT_DOWNLOAD_DIR=C:\\temp\\soul-sound-imports

# Optional (recommended for hosted/UI imports): YouTube cookies for yt-dlp fallback
# Use ONE option below:
# YTDLP_COOKIE_FILE=/absolute/path/to/cookies.txt
# YTDLP_COOKIES_B64=base64_encoded_netscape_cookie_file
# YTDLP_COOKIES_TEXT=raw_netscape_cookie_file_contents